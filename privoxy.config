###############################################################################
# privoxy.config — Configuration principale
###############################################################################

# Port d'écoute
listen-address 0.0.0.0:3128

# Logs désactivés (confidentialité + Docker)
logdir /dev/null
logfile /dev/null

# Fichiers d'actions (ordre : default < user, user écrase default)
actionsfile /etc/privoxy/default.action
actionsfile /etc/privoxy/user.action

# Fichiers de filtres
filterfile /etc/privoxy/default.filter
filterfile /etc/privoxy/user.filter

# Pas d'interface d'administration exposée
toggle 1
enable-remote-toggle 0
enable-remote-http-toggle 0
enable-edit-actions 0

# Compression : accepter gzip (nécessaire pour que les filtres regex fonctionnent)
# Privoxy décompresse automatiquement avant de filtrer
buffer-limit 10240