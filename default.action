###############################################################################
# default.action — Règles de blocage publicités & tracking
# Appliquées globalement, surchargées par user.action si besoin
###############################################################################

##
## 1. Activation des filtres sur tout le trafic
##
{ \
  +filter{remove-proxy-headers} \
  +filter{strip-utm-params} \
  +filter{strip-tracking-params} \
  +filter{remove-js-trackers} \
  +filter{anti-fingerprint} \
}
/

##
## 2. Blocage des domaines publicitaires et de tracking connus
##    Format : { +block{raison} } .domaine.com
##

